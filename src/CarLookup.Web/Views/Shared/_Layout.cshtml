<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Car Lookup</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="app-header">
        <div class="container d-flex align-items-center justify-content-between">
            <a class="app-brand" asp-controller="Home" asp-action="Index">
                <span class="app-brand-mark" aria-hidden="true">&#128663;</span>
                Car Lookup
            </a>
            <span class="app-header-note d-none d-sm-inline">Data: NHTSA vPIC</span>
        </div>
    </header>

    <main class="container py-4">
        @RenderBody()
    </main>

    <footer class="app-footer">
        <div class="container">
            Vehicle data provided by the
            <a href="https://vpic.nhtsa.dot.gov/api/" target="_blank" rel="noopener">NHTSA vPIC API</a>.
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
